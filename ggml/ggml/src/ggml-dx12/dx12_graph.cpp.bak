bool dx12_dispatch_soft_max(dx12_device* dev, dx12_command_list* cmd, ggml_tensor* dst) {
    uint32_t n = tensor_nelements(dst);
    uint32_t row_size = (uint32_t)dst->ne[0];
    float scale = 1.0f;
    struct { uint32_t n; uint32_t row_size; float scale; uint32_t pad; } params =
        { n, row_size, scale, 0 };

    const dx12_shader_entry* entry = dx12_get_shader_entry("soft_max");
    if (!entry) return false;
    dx12_pso_cache pso_cache(dev);
    uint3 tg = { (n + 255) / 256, 1, 1 };
    dx12_pso* pso = pso_cache.get_or_create("soft_max", entry->cso_data, entry->cso_size,
                                              dx12_root_signature_type::reduction, tg);
    if (!pso) return false;
    dx12_cmd_list_set_root_signature(cmd, pso->root_signature.Get());
    dx12_cmd_list_set_pso(cmd, pso->pipeline_state.Get());
    dx12_cmd_list_set_compute_root_32bit_constants(cmd, 0, 4, &params, 0);
    dx12_bind_tensor_srv(cmd, 1, dst->src[0]);
    dx12_bind_tensor_uav(cmd, 2, dst);
    dx12_cmd_list_dispatch(cmd, tg.x, 1, 1);
    return true;
}

bool dx12_dispatch_rms_norm(dx12_device* dev, dx12_command_list* cmd, ggml_tensor* dst) {
    uint32_t n = tensor_nelements(dst);
    uint32_t row_size = (uint32_t)dst->ne[0];
    float eps = 1e-6f;
    struct { uint32_t n; uint32_t row_size; float eps; uint32_t pad; } params =
        { n, row_size, eps, 0 };

    const dx12_shader_entry* entry = dx12_get_shader_entry("rms_norm");
    if (!entry) return false;
    dx12_pso_cache pso_cache(dev);
    uint3 tg = { (n + 255) / 256, 1, 1 };
    dx12_pso* pso = pso_cache.get_or_create("rms_norm", entry->cso_data, entry->cso_size,
                                              dx12_root_signature_type::reduction, tg);
    if (!pso) return false;
    dx12_cmd_list_set_root_signature(cmd, pso->root_signature.Get());
    dx12_cmd_list_set_pso(cmd, pso->pipeline_state.Get());
    dx12_cmd_list_set_compute_root_32bit_constants(cmd, 0, 4, &params, 0);
    dx12_bind_tensor_srv(cmd, 1, dst->src[0]);
    dx12_bind_tensor_uav(cmd, 2, dst);
    dx12_cmd_list_dispatch(cmd, tg.x, 1, 1);
    return true;
}

