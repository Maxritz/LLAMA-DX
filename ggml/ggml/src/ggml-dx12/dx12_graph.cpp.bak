bool dx12_dispatch_rope(dx12_device* dev, dx12_command_list* cmd, ggml_tensor* dst) {
    uint32_t n = tensor_nelements(dst);
    uint32_t head_dim = (uint32_t)dst->ne[0];
    uint32_t seq_len = (uint32_t)dst->ne[1];
    uint32_t num_heads = (uint32_t)dst->ne[2];
    float theta = 10000.0f;
    struct rope_params {
        uint32_t n, head_dim, seq_len, num_heads;
        float theta, scale;
        uint32_t pad[2];
    } params = { n, head_dim, seq_len, num_heads, theta, 1.0f, 0, 0 };

    const dx12_shader_entry* entry = dx12_get_shader_entry("rope");
    if (!entry) return false;
    dx12_pso_cache pso_cache(dev);
    uint3 tg = { (n + 255) / 256, 1, 1 };
    dx12_pso* pso = pso_cache.get_or_create("rope", entry->cso_data, entry->cso_size,
                                              dx12_root_signature_type::simple_2in_1out, tg);
    if (!pso) return false;
    dx12_cmd_list_set_root_signature(cmd, pso->root_signature.Get());
    dx12_cmd_list_set_pso(cmd, pso->pipeline_state.Get());
    dx12_cmd_list_set_compute_root_32bit_constants(cmd, 0, 8, &params, 0);
    dx12_bind_tensor_srv(cmd, 1, dst->src[0]);
    dx12_bind_tensor_uav(cmd, 3, dst);
    dx12_cmd_list_dispatch(cmd, tg.x, 1, 1);
    return true;
}

